# =============================================================================
# CRI Chatbot Platform — Variables d'environnement
# Copier vers .env et remplir les valeurs
# ATTENTION : .env ne doit JAMAIS etre versionne (deja dans .gitignore)
# Permissions recommandees : chmod 600 .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=cri_platform
POSTGRES_USER=cri_admin
POSTGRES_PASSWORD=              # OBLIGATOIRE — generer avec : openssl rand -base64 32
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=                 # OBLIGATOIRE — generer avec : openssl rand -base64 32
REDIS_HOST=redis
REDIS_PORT=6379

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=cri_minio
MINIO_ROOT_PASSWORD=            # OBLIGATOIRE — generer avec : openssl rand -base64 32
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# --- Traefik / TLS ---
ACME_EMAIL=                     # Email pour Let's Encrypt (prod uniquement)
BACKOFFICE_URL=http://localhost:3000

# --- Gemini API ---
GEMINI_API_KEY=                 # Cle API Google AI Studio

# --- WhatsApp (par tenant — configure via back-office) ---
WHATSAPP_APP_SECRET=            # App secret Meta pour validation HMAC webhook
WHATSAPP_VERIFY_TOKEN=          # Token de verification webhook

# --- Back-Office Auth ---
JWT_SECRET_KEY=                 # OBLIGATOIRE — generer avec : openssl rand -base64 64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Monitoring ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=               # OBLIGATOIRE — changer en prod

# --- Environnement ---
ENVIRONMENT=development         # development | staging | production
LOG_LEVEL=DEBUG                 # DEBUG | INFO | WARNING | ERROR

# --- Production Deployment ---
DOMAIN=                         # e.g., cri-platform.ma (Traefik routing: api.DOMAIN, admin.DOMAIN)
IMAGE_TAG=latest                # Docker image tag (set automatiquement par deploy.sh)

# --- Seed (premier deploiement uniquement) ---
SEED_ADMIN_EMAIL=               # Email du super-admin initial
SEED_ADMIN_PASSWORD=            # Min 12 chars, 1 majuscule, 1 chiffre, 1 caractere special
