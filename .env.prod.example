# =============================================================================
# CRI CHATBOT PLATFORM — PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# INSTRUCTIONS :
# 1. Copier ce fichier en .env.prod (JAMAIS versionne)
# 2. Remplir toutes les valeurs marquees CHANGE_ME
# 3. Generer les secrets avec les commandes indiquees
# 4. Deployer le .env sur chaque VPS selon ses besoins :
#    - VPS 1 (API)  : toutes les variables sauf ACME_EMAIL, GRAFANA_*
#    - VPS 2 (Data) : POSTGRES_*, REDIS_*, MINIO_*, VPS2_PRIVATE_IP
#    - VPS 3 (Front): IMAGE_TAG, DOCKER_REGISTRY, DOMAIN, ACME_EMAIL,
#                      VPS1_PRIVATE_IP, GRAFANA_*, GRAFANA_PASSWORD
#    - Staging      : toutes les variables
# =============================================================================

# --- Application -----------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
VERSION=0.3.0

# --- Domain ----------------------------------------------------------------
DOMAIN=chatbot.cri-rsk.ma
ACME_EMAIL=admin@cri-rsk.ma

# --- Docker Registry -------------------------------------------------------
DOCKER_REGISTRY=ghcr.io/ecologiciel/cri-chatbot
IMAGE_TAG=latest

# --- VPS Private IPs (reseau interne Nindohost) ----------------------------
VPS1_PRIVATE_IP=10.0.0.1   # API + Workers + Qdrant
VPS2_PRIVATE_IP=10.0.0.2   # PostgreSQL + Redis + MinIO
VPS3_PRIVATE_IP=10.0.0.3   # Frontend + Traefik + Monitoring

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_DB=cri_platform
POSTGRES_USER=cri_admin
POSTGRES_PASSWORD=CHANGE_ME           # openssl rand -hex 32

# --- Redis ------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME              # openssl rand -hex 32

# --- MinIO ------------------------------------------------------------------
MINIO_ROOT_USER=cri_minio
MINIO_ROOT_PASSWORD=CHANGE_ME         # openssl rand -hex 32

# --- Gemini API -------------------------------------------------------------
GEMINI_API_KEY=CHANGE_ME              # Google AI Studio

# --- WhatsApp Meta Cloud API ------------------------------------------------
WHATSAPP_APP_SECRET=CHANGE_ME         # Meta App Secret (HMAC webhook)
WHATSAPP_VERIFY_TOKEN=CHANGE_ME       # Webhook verification token

# --- JWT Auth ---------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME              # openssl rand -hex 64 (512 bits)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- KMS (Key Management Service) ------------------------------------------
KMS_MASTER_KEY=CHANGE_ME              # python -c "import secrets; print(secrets.token_hex(32))"

# --- Grafana ----------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME            # openssl rand -hex 16

# --- CORS -------------------------------------------------------------------
BACKOFFICE_URL=https://admin.chatbot.cri-rsk.ma

# --- Seed (premiere installation uniquement) --------------------------------
# SEED_ADMIN_EMAIL=admin@cri-rsk.ma
# SEED_ADMIN_PASSWORD=CHANGE_ME       # Mot de passe initial super_admin
